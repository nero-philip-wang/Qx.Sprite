{
  "AllowedHosts": "*",
  "AspNetPack": {
    "Core": {
      "FilePrefix": [
        "Demo"
      ]
    },
    "ServeInfo": {
      "ServeBaseUrl": "http://localhost:5000",
      "Version": "1.0.0",
      "Title": "api应用服务器"
    },
    "CorsHosts": [ "http://localhost:8080" ]
  },
  "Cache": {
    "CacheType": "InMemory",
    "Redis": {
      "ConnectionString": "localhost:6379",
      "Database": 0,
      "Password": "",
      "ConnectTimeout": 5000,
      "SyncTimeout": 5000,
      "KeyPrefix": "QxSprite:"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}